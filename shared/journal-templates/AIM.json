{
  "meta": {
    "journal": "Annals of Internal Medicine",
    "abbr": "AIM",
    "publisher": "American College of Physicians",
    "recommended_study_type": ["RCT", "cohort", "case-control", "diagnostic accuracy"],
    "guideline": "CONSORT/STROBE/STARD",
    "description": "Annals of Internal Medicine-style statistical analysis report template. Emphasizes clinical relevance, evidence quality assessment, and practical implications for internal medicine practice."
  },
  "sections": [
    {
      "id": "methods",
      "title": "Statistical Analysis",
      "order": 1,
      "type": "structured_methods",
      "paragraphs": [
        "Study design and population definition",
        "Sample size calculation and power justification",
        "Primary analysis: method, covariates, hypothesis test",
        "Secondary and exploratory analyses",
        "Subgroup analyses (pre-specified vs post-hoc)",
        "Sensitivity analyses (missing data, different assumptions)",
        "Multiple comparison adjustment (if applicable)",
        "Software and significance threshold",
        "Evidence quality assessment (GRADE framework)"
      ]
    },
    {
      "id": "results_baseline",
      "title": "Baseline Characteristics",
      "order": 2,
      "tables": [
        {"label": "Table 1", "title": "Baseline Characteristics of Study Participants",
         "type": "baseline_table", "format": "docx_three_line"}
      ]
    },
    {
      "id": "results_primary",
      "title": "Primary Outcome",
      "order": 3,
      "tables": [
        {"label": "Table 2", "title": "Primary Outcome Results",
         "type": "main_results_table", "format": "docx_three_line"}
      ],
      "figures": [
        {"label": "Figure 1", "title": "Primary Outcome",
         "type": "clinical_figure", "alt_types": ["km_curve", "forest_plot", "cumulative_incidence"]}
      ]
    },
    {
      "id": "results_secondary",
      "title": "Secondary Outcomes",
      "order": 4,
      "content": {"type": "narrative", "style": "brief"},
      "tables": [
        {"label": "Table 3", "title": "Secondary Outcomes",
         "type": "secondary_results_table", "format": "docx_three_line"}
      ]
    },
    {
      "id": "subgroup",
      "title": "Subgroup Analyses",
      "order": 5,
      "figures": [
        {"label": "Figure 2", "title": "Subgroup Analyses",
         "type": "forest_plot"}
      ]
    },
    {
      "id": "safety",
      "title": "Safety (if applicable)",
      "order": 6,
      "tables": [
        {"label": "Table 4", "title": "Adverse Events",
         "type": "safety_table", "format": "docx_three_line"}
      ]
    },
    {
      "id": "clinical_implications",
      "title": "Clinical Implications",
      "order": 7,
      "content": {"type": "narrative", "style": "clinical_relevance"}
    }
  ],
  "supplement": {
    "description": "Supplementary Appendix (online-only)",
    "sections": [
      {"id": "supp_methods", "title": "eMethods", "type": "supplement_detail"},
      {"id": "supp_tables", "title": "eTables", "type": "supplement_tables"},
      {"id": "supp_figures", "title": "eFigures", "type": "supplement_figures"}
    ]
  },
  "output_rules": {
    "table_format": "docx_three_line",
    "figure_dpi": 300,
    "figure_format": "tiff",
    "color_scheme": "AIM_green",
    "supplement_as_separate_file": true
  },
  "review_profile": {
    "review_style": "evidence_graded",
    "emphasis_dimensions": {
      "clinical_significance": 1.2,
      "methodological_rigor": 1.2,
      "evidence_sufficiency": 1.2,
      "writing_quality": 0.8
    },
    "eic_personality": "evidence_based_reviewer",
    "common_concerns": [
      "Is GRADE evidence quality reported?",
      "Are clinical implications clear?",
      "Is the sample size justified?"
    ],
    "devils_advocate_focus": "grade_framework_rigor",
    "tone": "balanced_academic"
  }
}