{
  "meta": {
    "journal": "The Lancet",
    "abbr": "Lancet",
    "publisher": "Elsevier",
    "recommended_study_type": ["RCT", "large cohort", "meta-analysis"],
    "guideline": "CONSORT / PRISMA",
    "description": "Lancet-style statistical analysis report. Highlights absolute risk differences, NNT/NNH, and clear clinical significance framing. Emphasis on concise main text with detailed supplement."
  },
  "sections": [
    {
      "id": "methods",
      "title": "Statistical Analysis",
      "order": 1,
      "type": "structured_methods",
      "paragraphs": [
        "Study design and participant flow",
        "Randomization and masking (if RCT)",
        "Primary and secondary outcome definitions",
        "Statistical methods for primary analysis",
        "Absolute risk difference and NNT calculation",
        "Subgroup and sensitivity analyses",
        "Role of the funding source",
        "Software (SAS/R/Stata version)"
      ]
    },
    {
      "id": "results_baseline",
      "title": "Baseline Characteristics",
      "order": 2,
      "tables": [
        {"label": "Table 1", "title": "Baseline Characteristics",
         "type": "baseline_table", "format": "docx_three_line"}
      ]
    },
    {
      "id": "results_primary",
      "title": "Primary Outcome",
      "order": 3,
      "content": {"type": "narrative_with_effect", "required_elements": ["absolute_risk", "relative_risk", "nnt_nnh"]},
      "tables": [
        {"label": "Table 2", "title": "Primary and Secondary Outcomes",
         "type": "main_results_table", "format": "docx_three_line"}
      ],
      "figures": [
        {"label": "Figure 1", "title": "Primary Outcome",
         "type": "clinical_figure", "alt_types": ["km_curve", "cumulative_incidence"]}
      ]
    },
    {
      "id": "subgroup",
      "title": "Subgroup Analyses",
      "order": 4,
      "figures": [
        {"label": "Figure 2", "title": "Subgroup Forest Plot",
         "type": "forest_plot", "show_absolute_risk": true}
      ]
    },
    {
      "id": "safety",
      "title": "Safety Outcomes",
      "order": 5,
      "tables": [
        {"label": "Table 3", "title": "Adverse Events",
         "type": "safety_table", "format": "docx_three_line"}
      ]
    }
  ],
  "supplement": {
    "description": "Supplementary Material (online)",
    "sections": [
      {"id": "supp_methods", "title": "Supplementary Methods", "type": "supplement_detail"},
      {"id": "supp_tables", "title": "Supplementary Tables", "type": "supplement_tables"},
      {"id": "supp_figures", "title": "Supplementary Figures", "type": "supplement_figures"}
    ]
  },
  "output_rules": {
    "table_format": "docx_three_line",
    "figure_dpi": 300,
    "figure_format": "tiff",
    "color_scheme": "Lancet_default",
    "supplement_as_separate_file": true
  },
  "review_profile": {
    "review_style": "global_impact",
    "emphasis_dimensions": {
      "clinical_significance": 1.3,
      "methodological_rigor": 1.0,
      "evidence_sufficiency": 1.0,
      "writing_quality": 0.8
    },
    "eic_personality": "global_health_expert",
    "common_concerns": [
      "Is the effect size clinically meaningful globally?",
      "Are NNT/NNH reported?",
      "Is the funding source role disclosed?"
    ],
    "devils_advocate_focus": "health_equity_blindspot",
    "tone": "concise_impactful"
  }
}



