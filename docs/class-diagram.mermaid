classDiagram
    direction TB

    class ScRNASeqLoader {
        -_adata: AnnData
        +read_10x_mtx(mtx_dir: str, var_names: str, cache: bool) AnnData
        +read_10x_h5(h5_path: str, genome: str) AnnData
        +read_csv(csv_path: str, **kwargs) AnnData
        +read_fasta(fasta_path: str) List
        +get_metadata() Dict
    }

    class SingleCellQC {
        +min_genes: int
        +max_genes: int
        +max_pct_mito: float
        +min_cells: int
        +compute_qc_metrics(adata) AnnData
        +filter_cells(adata, verbose: bool) AnnData
        +filter_genes(adata, verbose: bool) AnnData
        +run_qc(adata, verbose: bool) AnnData
        +get_qc_summary(adata) Dict
    }

    class DimensionalityReduction {
        +n_pcs: int
        +n_neighbors: int
        +normalize_and_log(adata, target_sum: int) AnnData
        +find_hvg(adata, n_top_genes: int) AnnData
        +run_pca(adata) AnnData
        +run_umap(adata) AnnData
        +cluster(adata, resolution: float) AnnData
        +run_full_pipeline(adata, resolution: float) AnnData
    }

    class DifferentialExpression {
        +method: str
        +find_markers(adata, groupby: str, use_raw: bool) DataFrame
        +get_de_table(adata, group: str, n_genes: int) DataFrame
        +filter_de_genes(de_table, log2fc_threshold: float, pval_threshold: float) DataFrame
    }

    class TrajectoryAnalysis {
        +method: str
        +run_paga(adata, groups: str) AnnData
        +run_dpt(adata, root_key: str) AnnData
    }

    class BioVisualizer {
        +figsize: tuple
        +dpi: int
        +plot_umap(adata, color: str, save_path: str) Figure
        +plot_violin(adata, keys: List, groupby: str, save_path: str) Figure
        +plot_dotplot(adata, var_names: List, groupby: str, save_path: str) Figure
        +plot_heatmap(adata, var_names: List, groupby: str, save_path: str) Figure
        +plot_paga(adata, color: str, save_path: str) Figure
    }

    class CellBenderDenoiser {
        +expected_cells: int
        +total_droplets: int
        +epochs: int
        +check_installation() bool
        +run_remove_background(input_h5, output_h5, expected_cells, total_droplets) Dict
        +load_denoised(h5_path) AnnData
        +compare_before_after(raw_adata, denoised_adata) Dict
    }

    class PathwayEnrichment {
        +organism: str
        +gene_sets: str
        +outdir: str
        +run_enrichr(gene_list: List, gene_sets_libraries: List, cutoff: float) DataFrame
        +run_gsea(rnk: Series, gene_sets: str, min_size: int, max_size: int) DataFrame
        +run_go(gene_list: List, ontology: str, cutoff: float) DataFrame
        +run_kegg(gene_list: List, cutoff: float) DataFrame
        +get_top_pathways(results: DataFrame, n: int, sort_by: str) DataFrame
        +export_results(results: DataFrame, output_path: str, format: str) str
    }

    class BatchCorrector {
        +batch_key: str
        +method: str
        +detect_batch_effect(adata, n_pcs: int) Dict
        +run_combat(adata, key: str) AnnData
        +run_harmony(adata, basis: str, adjusted_basis: str) AnnData
        +compare_before_after(adata_raw, adata_corrected) Dict
    }

    class BioQualityGateChecker {
        -study_id: str
        -_runner: GateRunner
        +gate_bio_1_5(adata, sample_info: DataFrame, batch_key: str) GateResult
        +gate_bio_3_5(de_results: DataFrame, enrichment_results: DataFrame, visualization_paths: List) GateResult
        +register_bio_gates()$
        -_check_count_matrix_integrity(adata) CheckItemResult
        -_check_sample_consistency(adata, sample_info) CheckItemResult
        -_check_library_size(adata) CheckItemResult
        -_check_gene_annotation(adata) CheckItemResult
        -_check_batch_effect(adata, batch_key: str) CheckItemResult
        -_check_pvalue_distribution(pvalues: Series) CheckItemResult
        -_check_effect_consistency(log2fc: Series, pvalues: Series) CheckItemResult
        -_check_multiple_testing(pvalues: Series, padj: Series) CheckItemResult
        -_check_enrichment_fdr(enrichment_df: DataFrame) CheckItemResult
        -_check_visualization_consistency(visualization_paths: List, de_table: DataFrame) CheckItemResult
    }

    class GateRunner {
        +study_id: str
        +get_gate_definition(gate_type) GateDefinition
        +generate_checklist(gate_type, artifacts: Dict) str
        +build_agent_task(gate_type, artifacts: Dict, output_path: str) Dict
        +run_gate(gate_type, artifacts: Dict, mode: RunMode, check_results: List) GateResult
        +load_gate_report(report_path: str) GateResult
        +save_gate_report(result: GateResult, output_path: str) str
    }

    class GateResult {
        +gate_type: GateType
        +study_id: str
        +verdict: GateVerdict
        +total_items: int
        +passed_items: int
        +failed_items: int
        +key_items_status: str
        +check_results: List~CheckItemResult~
        +risks: List~str~
        +timestamp: str
        +mode: RunMode
        +pass_rate: float
        +to_dict() Dict
    }

    class CheckItemResult {
        +item_id: str
        +name: str
        +is_key: bool
        +status: str
        +evidence: str
        +notes: str
    }

    %% 关系
    BioQualityGateChecker --> GateRunner : 复用门闸执行器
    BioQualityGateChecker --> CheckItemResult : 产出检查结果
    GateRunner --> GateResult : 返回门闸结果
    GateResult *-- CheckItemResult : 包含多个

    PathwayEnrichment ..> DifferentialExpression : 消费差异基因列表
    BatchCorrector ..> DimensionalityReduction : 校正后可重新降维

    ScRNASeqLoader --> SingleCellQC : 输出AnnData
    SingleCellQC --> DimensionalityReduction : 输出QC后AnnData
    DimensionalityReduction --> DifferentialExpression : 输出标准化AnnData
    DifferentialExpression --> PathwayEnrichment : 输出基因列表
    DifferentialExpression --> BioVisualizer : 输出DE表供可视化
